@{
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <title>Yeni Şifre Belirle</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
    <div class="container mt-5" style="max-width:500px;">
        <div class="card shadow">
            <div class="card-body">
                <h3 class="mb-4 text-center">Yeni Şifre</h3>
                <div id="alertBox" class="alert d-none"></div>
                <form id="resetForm">
                    <input type="hidden" id="email" value="@ViewBag.Email">
                    <input type="hidden" id="token" value="@ViewBag.Token">
                    <div class="mb-3">
                        <label>Yeni şifre</label>
                        <input type="password" id="newPassword" class="form-control" required minlength="6">
                    </div>
                    <button type="submit" class="btn btn-success w-100">Şifreyi Güncelle</button>
                </form>
                <div class="text-center mt-3">
                    <a href="/Auth/Login">Giriş yap</a>
                </div>
            </div>
        </div>
    </div>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        const apiBaseUrl = "http://localhost:5229";
        $("#resetForm").submit(function(e){
            e.preventDefault();
            $.ajax({
                url: `${apiBaseUrl}/api/Auth/reset-password`,
                type: "POST",
                contentType: "application/json",
                data: JSON.stringify({
                    email: $("#email").val(),
                    token: $("#token").val(),
                    newPassword: $("#newPassword").val()
                }),
                success: function(){
                    $("#alertBox").removeClass("d-none alert-danger").addClass("alert-success").text("Şifre değiştirildi, giriş yapabilirsiniz.");
                    setTimeout(() => window.location.href = "/Auth/Login", 2000);
                },
                error: function(err){
                    let msg = "Hata oluştu.";
                    if (err.responseJSON) msg = err.responseJSON.title || JSON.stringify(err.responseJSON);
                    $("#alertBox").removeClass("d-none alert-success").addClass("alert-danger").text(msg);
                }
            });
        });
    </script>
</body>
</html>