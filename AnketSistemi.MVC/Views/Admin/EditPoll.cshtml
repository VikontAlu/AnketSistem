@{
    ViewData["Title"] = "Anket Düzenle";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    var apiBaseUrl = ViewBag.ApiBaseUrl as string ?? "http://localhost:5229";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold"><i class="bi bi-pencil-square text-warning me-2"></i>Anket Düzenle</h2>
    <a href="/Admin/Results/@ViewBag.PollId" class="btn btn-info ms-2">
        <i class="bi bi-bar-chart"></i> Sonuçları Gör
    </a>
    <a href="/Admin/Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Panele Dön</a>
</div>

<div id="alertBox" class="alert d-none"></div>

<div class="card shadow mb-4">
    <div class="card-body">
        <form id="editPollForm">
            <div class="mb-3">
                <label class="fw-bold">Başlık</label>
                <input type="text" id="title" class="form-control" required>
            </div>
            <div class="mb-3">
                <label class="fw-bold">Açıklama</label>
                <textarea id="detail" class="form-control" rows="3"></textarea>
            </div>
            <div class="mb-3">
                <label class="fw-bold">Bitiş Tarihi</label>
                <input type="datetime-local" id="expireDate" class="form-control" required>
            </div>
            <div class="mb-3">
                <label class="fw-bold">Aktif</label>
                <select id="isActive" class="form-select">
                    <option value="true">Aktif</option>
                    <option value="false">Pasif</option>
                </select>
            </div>
            <button type="submit" class="btn btn-primary">Güncelle</button>
        </form>
    </div>
</div>

<h4>Sorular</h4>
<div class="card shadow">
    <div class="card-body">
        <table class="table" id="questionsTable">
            <thead><tr><th>Soru</th><th>Format</th><th>İşlemler</th></tr></thead>
            <tbody></tbody>
        </table>
        <a id="addQuestionBtn" href="#" class="btn btn-success btn-sm"><i class="bi bi-plus"></i> Yeni Soru Ekle</a>
    </div>
</div>

@section Scripts {
    <script>
        const pollId = @ViewBag.PollId;
        const apiBaseUrl = "@apiBaseUrl";

        $(function(){
            // Anket bilgilerini yükle
            $.get(`${apiBaseUrl}/api/Poll/${pollId}`, function(poll){
                $("#title").val(poll.title);
                $("#detail").val(poll.detail);
                $("#expireDate").val(poll.expireDate.slice(0,16));
                $("#isActive").val(poll.isActive.toString());
                loadQuestions();
            });

            function loadQuestions(){
                $.get(`${apiBaseUrl}/api/Poll/${pollId}`, function(poll){
                    let rows = "";
                    poll.questions.forEach(q => {
                        rows += `<tr>
                            <td>${q.questionText}</td>
                            <td>${q.format === 2 ? 'Çoktan Seçmeli' : 'Metin'}</td>
                            <td>
                                <a href="/Admin/AddQuestion/${pollId}?questionId=${q.id}" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i></a>
                                <button class="btn btn-sm btn-outline-danger delete-question" data-id="${q.id}"><i class="bi bi-trash"></i></button>
                            </td>
                        </tr>`;
                    });
                    $("#questionsTable tbody").html(rows);
                    $("#addQuestionBtn").attr("href", `/Admin/AddQuestion/${pollId}`);
                });
            }

            $(document).on("click", ".delete-question", function(){
                if (!confirm("Soruyu silmek istediğinize emin misiniz?")) return;
                const id = $(this).data("id");
                $.ajax({
                    url: `${apiBaseUrl}/api/Poll/Question/${id}`,
                    type: "DELETE",
                    headers: { "Authorization": "Bearer " + localStorage.getItem("token") },
                    success: function(){
                        loadQuestions();
                    }
                });
            });

            $("#editPollForm").submit(function(e){
                e.preventDefault();
                const data = {
                    id: pollId,
                    title: $("#title").val(),
                    detail: $("#detail").val(),
                    expireDate: $("#expireDate").val(),
                    isActive: $("#isActive").val() === "true"
                };
                $.ajax({
                    url: `${apiBaseUrl}/api/Poll`,
                    type: "PUT",
                    contentType: "application/json",
                    headers: { "Authorization": "Bearer " + localStorage.getItem("token") },
                    data: JSON.stringify(data),
                    success: function(){
                        $("#alertBox").removeClass("d-none alert-danger").addClass("alert-success").text("Anket güncellendi.");
                    },
                    error: function(){
                        $("#alertBox").removeClass("d-none alert-success").addClass("alert-danger").text("Güncelleme başarısız.");
                    }
                });
            });
        });
    </script>
}