@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <title>Kayıt Ol | Anket Sistemi</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body {
            background: #f4f7f6;
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .register-card {
            width: 450px;
            border: none;
            border-radius: 15px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
        }

        .btn-success {
            background: #28a745;
            border: none;
            border-radius: 8px;
            padding: 12px;
        }
    </style>
</head>
<body>

    <div class="card register-card p-4">
        <div class="text-center mb-4">
            <h3 class="fw-bold text-success">Yeni Hesap Oluştur</h3>
            <p class="text-muted">Anket Sistemine Katılın</p>
        </div>
        <div id="alertBox" class="alert d-none"></div>
        <form id="registerForm">
            <div class="mb-3">
                <label class="form-label fw-bold">Ad Soyad</label>
                <input type="text" id="fullName" class="form-control form-control-lg" placeholder="Adınız Soyadınız" required>
            </div>
            <div class="mb-3">
                <label class="form-label fw-bold">E-Posta</label>
                <input type="email" id="email" class="form-control form-control-lg" placeholder="ornek@mail.com" required>
            </div>
            <div class="mb-4">
                <label class="form-label fw-bold">Şifre</label>
                <input type="password" id="password" class="form-control form-control-lg" placeholder="******" required>
            </div>
            <button type="submit" class="btn btn-success w-100 fw-bold">Kayıt Ol</button>
            <div class="text-center mt-3">
                <a href="/Auth/Login" class="text-decoration-none text-primary">Zaten hesabın var mı? Giriş Yap</a>
            </div>
        </form>
    </div>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        $(document).ready(function () {
            $("#registerForm").submit(function (e) {
                e.preventDefault();

                const registerData = {
                    fullName: $("#fullName").val(),
                    email: $("#email").val(),
                    password: $("#password").val()
                };

                // DİKKAT: 7122 Yazan yeri API projenin portu ile değiştirmeyi unutma!
                $.ajax({
                    url: "https://localhost:7122/api/Auth/register",
                    type: "POST",
                    contentType: "application/json",
                    data: JSON.stringify(registerData),
                    success: function (response) {
                        $("#alertBox").removeClass("d-none alert-danger").addClass("alert-success").text("Kayıt Başarılı! Giriş sayfasına yönlendiriliyorsunuz...");
                        setTimeout(() => { window.location.href = "/Auth/Login"; }, 2000);
                    },
                    error: function (err) {
                        $("#alertBox").removeClass("d-none alert-success").addClass("alert-danger").text("Hata: Kayıt işlemi başarısız. Bilgileri kontrol edin.");
                    }
                });
            });
        });
    </script>
</body>
</html>