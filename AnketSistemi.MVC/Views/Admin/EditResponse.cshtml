@{
    ViewData["Title"] = "Cevabı Düzenle";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    var apiBaseUrl = ViewBag.ApiBaseUrl as string ?? "http://localhost:5229";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold"><i class="bi bi-pencil-square text-warning me-2"></i>Cevabı Düzenle</h2>
    <a href="/Admin/ViewResponses" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Listeye Dön</a>
</div>

<div class="card shadow">
    <div class="card-body">
        <div id="alertBox" class="alert d-none"></div>
        <form id="editForm">
            <div class="mb-3">
                <label class="fw-bold">Soru</label>
                <p id="questionText" class="form-control-plaintext"></p>
            </div>
            <div id="choicesContainer" class="mb-3">
                <!-- radyo butonları dinamik oluşacak -->
            </div>
            <div class="mb-3">
                <label class="fw-bold">Yazılı Cevap</label>
                <textarea id="writtenAnswer" class="form-control" rows="3"></textarea>
            </div>
            <button type="submit" class="btn btn-primary">Kaydet</button>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        const apiBaseUrl = "@apiBaseUrl";
        const responseId = @ViewBag.ResponseId;
        $(function(){
            $.ajax({
                url: `${apiBaseUrl}/api/Response/${responseId}`,
                headers: { "Authorization": "Bearer " + localStorage.getItem("token") },
                success: function(data){
                    $("#questionText").text(data.questionText);
                    let html = "";
                    if (data.choices && data.choices.length > 0) {
                        data.choices.forEach(c => {
                            html += `<div class="form-check">
                                <input class="form-check-input" type="radio" name="selectedChoice" value="${c.id}" ${c.id === data.selectedChoiceId ? 'checked' : ''}>
                                <label class="form-check-label">${c.text}</label>
                            </div>`;
                        });
                    }
                    $("#choicesContainer").html(html);
                    $("#writtenAnswer").val(data.writtenAnswer || "");
                }
            });

            $("#editForm").submit(function(e){
                e.preventDefault();
                const selectedChoice = $("input[name='selectedChoice']:checked").val();
                const payload = {
                    selectedOptionId: selectedChoice ? parseInt(selectedChoice) : null,
                    textAnswer: $("#writtenAnswer").val() || null
                };

                $.ajax({
                    url: `${apiBaseUrl}/api/Response/${responseId}`,
                    type: "PUT",
                    contentType: "application/json",
                    headers: { "Authorization": "Bearer " + localStorage.getItem("token") },
                    data: JSON.stringify(payload),
                    success: function(){
                        $("#alertBox").removeClass("d-none alert-danger").addClass("alert-success").text("Cevap güncellendi.");
                        setTimeout(() => window.location.href = "/Admin/ViewResponses", 1500);
                    },
                    error: function(){
                        $("#alertBox").removeClass("d-none alert-success").addClass("alert-danger").text("Hata oluştu.");
                    }
                });
            });
        });
    </script>
}