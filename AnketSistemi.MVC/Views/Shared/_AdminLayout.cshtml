<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin Paneli | Anket Sistemi</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
    <style>
        body {
            display: flex;
            min-height: 100vh;
            background-color: #f8f9fa;
        }
        .sidebar {
            width: 250px;
            background-color: #343a40;
            color: white;
            padding: 20px;
        }
        .sidebar a {
            color: #adb5bd;
            text-decoration: none;
            display: block;
            margin-bottom: 15px;
            font-size: 16px;
        }
        .sidebar a:hover {
            color: white;
        }
        .content {
            flex-grow: 1;
            padding: 30px;
        }
    </style>
</head>
<body>
    <div class="sidebar">
        <h4 class="mb-4 text-center fw-bold text-warning"><i class="bi bi-shield-lock"></i> Yonetim</h4>
        <a href="/Admin/Index"><i class="bi bi-speedometer2 me-2"></i> Gosterge Paneli</a>
        <a href="#"><i class="bi bi-card-checklist me-2"></i> Anketler</a>
        <a href="#"><i class="bi bi-people me-2"></i> Kullanicilar</a>
        <hr class="border-secondary">
        <a href="#" onclick="logoutAdmin()" class="text-danger"><i class="bi bi-box-arrow-right me-2"></i> Cikis Yap</a>
        <a href="/Home/Index" class="text-info mt-3"><i class="bi bi-house me-2"></i> Siteye Don</a>
    </div>
    <div class="content">
        @RenderBody()
    </div>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        $(document).ready(function () {
            const token = localStorage.getItem("token");
            if (!token) {
                alert("Bu sayfayi goruntulемek icin giris yapmaniz gerekiyor!");
                window.location.href = "/Auth/Login";
            }
        });
        function logoutAdmin() {
            localStorage.removeItem("token");
            window.location.href = "/Auth/Login";
        }
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
