@{
    ViewData["Title"] = (ViewBag.QuestionId != null ? "Soruyu Düzenle" : "Ankete Soru Ekle");
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    var apiBaseUrl = ViewBag.ApiBaseUrl as string ?? "http://localhost:5229";
    var questionId = ViewBag.QuestionId as int?;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold"><i class="bi bi-question-square text-success me-2"></i>@ViewData["Title"]</h2>
    <a href="/Admin/EditPoll/@ViewBag.PollId" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Ankete Dön</a>
</div>

<div class="row">
    <div class="col-md-8">
        <div class="card shadow-sm border-0">
            <div class="card-body p-4">
                <div id="alertBox" class="alert d-none"></div>

                <form id="addQuestionForm">
                    <input type="hidden" id="questionId" value="@questionId">
                    <div class="mb-4">
                        <label class="form-label fw-bold">Soru Metni</label>
                        <input type="text" id="questionText" class="form-control form-control-lg" required>
                    </div>

                    <div class="mb-3 d-flex justify-content-between align-items-center">
                        <label class="form-label fw-bold mb-0">Seçenekler (Şıklar)</label>
                        <button type="button" class="btn btn-sm btn-outline-primary" id="addChoiceBtn">
                            <i class="bi bi-plus"></i> Yeni Seçenek Ekle
                        </button>
                    </div>

                    <div id="choicesContainer">
                    </div>

                    <hr class="my-4">
                    <div class="text-end">
                        <button type="submit" class="btn btn-success btn-lg fw-bold px-5">
                            <i class="bi bi-check2-circle"></i> @((questionId != null) ? "Güncelle" : "Kaydet")
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const currentPollId = @ViewBag.PollId;
        const questionId = @(questionId ?? 0);
        const apiBaseUrl = "@apiBaseUrl";
        const letters = ["A","B","C","D","E","F","G","H"];
        let currentChoices = []; 

        $(function(){
            if (questionId > 0) {

                $.get(`${apiBaseUrl}/api/Poll/${currentPollId}`, function(poll){
                    const question = poll.questions.find(q => q.id == questionId);
                    if (!question) return;
                    $("#questionText").val(question.questionText);
                    currentChoices = question.choices;
                    renderChoices();
                });
            } else {
 
                currentChoices = [{ choiceText: "", orderIndex: 0 }, { choiceText: "", orderIndex: 1 }];
                renderChoices();
            }

            function renderChoices() {
                let html = "";
                currentChoices.forEach((c, i) => {
                    html += `<div class="input-group mb-2 choice-row" data-index="${i}">
                        <span class="input-group-text bg-light">${letters[i] || i+1}</span>
                        <input type="text" class="form-control choice-input" value="${c.choiceText || ''}" placeholder="Seçenek ${i+1}" required>
                        <button type="button" class="btn btn-danger remove-choice" ${currentChoices.length <= 2 ? 'disabled' : ''}><i class="bi bi-trash"></i></button>
                    </div>`;
                });
                $("#choicesContainer").html(html);
            }


            $("#addChoiceBtn").click(function(){
                currentChoices.push({ choiceText: "", orderIndex: currentChoices.length });
                renderChoices();
            });

            $(document).on("click", ".remove-choice", function(){
                if (currentChoices.length <= 2) return;
                const index = $(this).closest(".choice-row").data("index");
                currentChoices.splice(index, 1);
                renderChoices();
            });

            $("#addQuestionForm").submit(function(e){
                e.preventDefault();
                const token = localStorage.getItem("token");
                if (!token) { window.location.href = "/Auth/Login"; return; }
                $(".choice-input").each(function(i){
                    if (i < currentChoices.length) {
                        currentChoices[i].choiceText = $(this).val().trim();
                    }
                });

                if (questionId > 0) {
                    updateQuestion(token);
                } else {
                    createQuestion(token);
                }
            });

            function createQuestion(token) {
                const questionData = {
                    pollId: currentPollId,
                    questionText: $("#questionText").val(),
                    format: 2,
                    isMandatory: true
                };
                $.ajax({
                    url: `${apiBaseUrl}/api/Poll/AddQuestion`,
                    type: "POST",
                    contentType: "application/json",
                    headers: { "Authorization": "Bearer " + token },
                    data: JSON.stringify(questionData),
                    success: function(res){
                        const qId = res.questionId;
                        let promises = currentChoices.map((c, i) => {
                            return $.ajax({
                                url: `${apiBaseUrl}/api/Poll/AddChoice`,
                                type: "POST",
                                contentType: "application/json",
                                headers: { "Authorization": "Bearer " + token },
                                data: JSON.stringify({ pollQuestionId: qId, choiceText: c.choiceText, orderIndex: i })
                            });
                        });
                        Promise.all(promises).then(() => {
                            $("#alertBox").removeClass("d-none alert-danger").addClass("alert-success").text("Soru eklendi.");
                            setTimeout(() => window.location.href = `/Admin/EditPoll/${currentPollId}`, 1500);
                        });
                    },
                    error: function(){ alert("Hata"); }
                });
            }

            function updateQuestion(token) {
                $.ajax({
                    url: `${apiBaseUrl}/api/Poll/Question/${questionId}`,
                    type: "PUT",
                    contentType: "application/json",
                    headers: { "Authorization": "Bearer " + token },
                    data: JSON.stringify({ pollId: currentPollId, questionText: $("#questionText").val(), format: 2, isMandatory: true }),
                    success: function(){
                        $.get(`${apiBaseUrl}/api/Poll/${currentPollId}`, function(poll){
                            const question = poll.questions.find(q => q.id == questionId);
                            if (!question) return;

                            let deletePromises = question.choices.map(c => $.ajax({
                                url: `${apiBaseUrl}/api/Poll/Choice/${c.id}`,
                                type: "DELETE",
                                headers: { "Authorization": "Bearer " + token }
                            }));
                            Promise.all(deletePromises).then(() => {
                                let addPromises = currentChoices.map((c, i) => $.ajax({
                                    url: `${apiBaseUrl}/api/Poll/AddChoice`,
                                    type: "POST",
                                    contentType: "application/json",
                                    headers: { "Authorization": "Bearer " + token },
                                    data: JSON.stringify({ pollQuestionId: questionId, choiceText: c.choiceText, orderIndex: i })
                                }));
                                Promise.all(addPromises).then(() => {
                                    $("#alertBox").removeClass("d-none alert-danger").addClass("alert-success").text("Güncellendi.");
                                    setTimeout(() => window.location.href = `/Admin/EditPoll/${currentPollId}`, 1500);
                                });
                            });
                        });
                    },
                    error: function(){ alert("Güncelleme hatası"); }
                });
            }
        });
    </script>
}