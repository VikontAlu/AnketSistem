@{
    ViewData["Title"] = "Gösterge Paneli";
    Layout = "~/Views/Shared/_AdminLayout.cshtml"; // Kendi özel admin layoutumuzu kullanıyoruz
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold">Gösterge Paneli</h2>
    <button class="btn btn-primary"><i class="bi bi-plus-lg"></i> Yeni Anket Oluştur</button>
</div>

<div class="card shadow-sm border-0">
    <div class="card-header bg-white border-bottom-0 pt-4 pb-0">
        <h5 class="fw-bold text-secondary">Sistemdeki Tüm Anketler</h5>
    </div>
    <div class="card-body">
        <table class="table table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th>Anket Başlığı</th>
                    <th>Oluşturulma Tarihi</th>
                    <th>Görüntülenme</th>
                    <th>Durum</th>
                    <th>İşlemler</th>
                </tr>
            </thead>
            <tbody id="adminPollTable">
                <tr><td colspan="5" class="text-center text-muted">Veriler API'den yükleniyor...</td></tr>
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            // API'den tüm anketleri çek
            $.ajax({
                url: "https://localhost:5229/api/Poll", // KENDİ PORTUNU YAZMAYI UNUTMA
                type: "GET",
                // Token'ı başlığa ekliyoruz (Gelecekte sadece adminler görsün diye güvenlik için)
                headers: { "Authorization": "Bearer " + localStorage.getItem("token") },
                success: function(data) {
                    let rows = "";
                    if (data.length === 0) {
                        rows = "<tr><td colspan='5' class='text-center text-warning'>Henüz anket eklenmemiş.</td></tr>";
                    } else {
                        data.forEach(function(poll) {
                            rows += `
                                <tr>
                                    <td class="fw-bold">${poll.title}</td>
                                    <td>${new Date().toLocaleDateString('tr-TR')}</td>
                                    <td><span class="badge bg-info text-dark">${poll.totalViews || 0} Görüntülenme</span></td>
                                    <td><span class="badge bg-success">Aktif</span></td>
                                    <td>
                                        <button class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i></button>
                                        <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                                    </td>
                                </tr>
                            `;
                        });
                    }
                    $("#adminPollTable").html(rows);
                },
                error: function(err) {
                    $("#adminPollTable").html("<tr><td colspan='5' class='text-center text-danger'>Veriler çekilemedi! API çalışıyor mu?</td></tr>");
                }
            });
        });
    </script>
}