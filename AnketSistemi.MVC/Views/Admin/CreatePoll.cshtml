@{
    ViewData["Title"] = "Yeni Anket Olustur";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    var apiBaseUrl = ViewBag.ApiBaseUrl as string ?? "http://localhost:5229";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold text-dark"><i class="bi bi-plus-circle-fill text-primary me-2"></i>Yeni Anket Olustur</h2>
    <a href="/Admin/Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Panele Don</a>
</div>

<div class="card shadow-sm border-0" style="max-width: 800px;">
    <div class="card-body p-4">
        <div id="alertBox" class="alert d-none"></div>

        <form id="createPollForm">
            <div class="mb-3">
                <label class="form-label fw-bold">Anket Basligi</label>
                <input type="text" id="title" class="form-control form-control-lg" placeholder="Orn: 2026 Yazilim Trendleri" required>
            </div>

            <div class="mb-3">
                <label class="form-label fw-bold">Anket Aciklamasi (Detay)</label>
                <textarea id="detail" class="form-control" rows="3" placeholder="Kullanicilara anketin amacini kisaca aciklayin..."></textarea>
            </div>

            <div class="mb-4">
                <label class="form-label fw-bold">Bitis Tarihi</label>
                <input type="datetime-local" id="expireDate" class="form-control" required>
            </div>

            <div class="text-end">
                <button type="submit" class="btn btn-primary btn-lg fw-bold px-5">
                    <i class="bi bi-save2"></i> Anketi Kaydet
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        const apiBaseUrl = "@apiBaseUrl";

        $(document).ready(function () {
            let tomorrow = new Date();
            tomorrow.setDate(tomorrow.getDate() + 1);
            tomorrow.setMinutes(tomorrow.getMinutes() - tomorrow.getTimezoneOffset());
            $("#expireDate").val(tomorrow.toISOString().slice(0, 16));

            $("#createPollForm").submit(function (e) {
                e.preventDefault();

                const token = localStorage.getItem("token");
                if (!token) {
                    alert("Oturumunuz dusmis. Lutfen tekrar giris yapin.");
                    window.location.href = "/Auth/Login";
                    return;
                }

                const pollData = {
                    title: $("#title").val(),
                    detail: $("#detail").val(),
                    expireDate: $("#expireDate").val()
                };

                $.ajax({
                    url: `${apiBaseUrl}/api/Poll`,
                    type: "POST",
                    contentType: "application/json",
                    headers: { "Authorization": "Bearer " + token },
                    data: JSON.stringify(pollData),
                    success: function (response) {
                        $("#alertBox").removeClass("d-none alert-danger").addClass("alert-success")
                                      .text("Anket basariyla olusturuldu! Soru eklemek ister misiniz?");
                        setTimeout(() => {
                            window.location.href = `/Admin/AddQuestion/${response.pollId}`;
                        }, 1500);
                    },
                    error: function (err) {
                        $("#alertBox").removeClass("d-none alert-success").addClass("alert-danger")
                                      .text("Hata: Anket olusturulamadi. Lutfen bilgileri kontrol edin.");
                    }
                });
            });
        });
    </script>
}
