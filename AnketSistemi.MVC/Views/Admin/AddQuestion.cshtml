@{
    ViewData["Title"] = "Ankete Soru Ekle";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold text-dark"><i class="bi bi-question-square text-success me-2"></i>Soru Ekle</h2>
    <a href="/Admin/Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Panele Dön</a>
</div>

<div class="row">
    <div class="col-md-8">
        <div class="card shadow-sm border-0">
            <div class="card-body p-4">
                <div id="alertBox" class="alert d-none"></div>

                <form id="addQuestionForm">
                    <div class="mb-4">
                        <label class="form-label fw-bold">Soru Metni</label>
                        <input type="text" id="questionText" class="form-control form-control-lg" placeholder="Örn: En sevdiğiniz programlama dili hangisidir?" required>
                    </div>

                    <div class="mb-3 d-flex justify-content-between align-items-center">
                        <label class="form-label fw-bold mb-0">Seçenekler (Şıklar)</label>
                        <button type="button" class="btn btn-sm btn-outline-primary" id="addChoiceBtn">
                            <i class="bi bi-plus"></i> Yeni Seçenek Ekle
                        </button>
                    </div>

                    <div id="choicesContainer">
                        <div class="input-group mb-2 choice-row">
                            <span class="input-group-text bg-light"><i class="bi bi-record-circle text-primary"></i></span>
                            <input type="text" class="form-control choice-input" placeholder="Seçenek 1" required>
                            <button type="button" class="btn btn-danger remove-choice" disabled><i class="bi bi-trash"></i></button>
                        </div>
                        <div class="input-group mb-2 choice-row">
                            <span class="input-group-text bg-light"><i class="bi bi-record-circle text-primary"></i></span>
                            <input type="text" class="form-control choice-input" placeholder="Seçenek 2" required>
                            <button type="button" class="btn btn-danger remove-choice"><i class="bi bi-trash"></i></button>
                        </div>
                    </div>

                    <hr class="my-4">

                    <div class="text-end">
                        <button type="submit" class="btn btn-success btn-lg fw-bold px-5">
                            <i class="bi bi-check2-circle"></i> Soruyu Ankete Kaydet
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const currentPollId = @ViewBag.PollId; // Controller'dan gelen Anket ID
        const apiUrl = "https://localhost:7122"; // KENDİ API PORTUNU YAZMAYI UNUTMA!

        $(document).ready(function () {

            // Dinamik Seçenek Ekleme
            $("#addChoiceBtn").click(function() {
                let choiceCount = $(".choice-row").length + 1;
                let newRow = `
                    <div class="input-group mb-2 choice-row">
                        <span class="input-group-text bg-light"><i class="bi bi-record-circle text-primary"></i></span>
                        <input type="text" class="form-control choice-input" placeholder="Seçenek ${choiceCount}" required>
                        <button type="button" class="btn btn-danger remove-choice"><i class="bi bi-trash"></i></button>
                    </div>
                `;
                $("#choicesContainer").append(newRow);
            });

            // Seçenek Silme
            $(document).on("click", ".remove-choice", function() {
                if ($(".choice-row").length > 2) { // En az 2 seçenek kalmasını zorla
                    $(this).closest(".choice-row").remove();
                } else {
                    alert("Bir sorunun en az 2 seçeneği olmalıdır!");
                }
            });

            // Formu API'ye Gönderme
            $("#addQuestionForm").submit(function (e) {
                e.preventDefault();

                // Token kontrolü
                const token = localStorage.getItem("token");
                if (!token) {
                    window.location.href = "/Auth/Login";
                    return;
                }

                // Seçenekleri topla
                let choicesArray = [];
                $(".choice-input").each(function() {
                    let val = $(this).val().trim();
                    if (val) {
                        choicesArray.push({ text: val }); // API'deki QuestionChoice modeline uygun obje
                    }
                });

                // API'nin beklediği PollQuestion nesnesi
                const questionData = {
                    pollId: currentPollId,
                    text: $("#questionText").val(),
                    choices: choicesArray
                };

                $.ajax({
                    url: `${apiUrl}/api/PollQuestion`,
                    type: "POST",
                    contentType: "application/json",
                    headers: { "Authorization": "Bearer " + token },
                    data: JSON.stringify(questionData),
                    success: function (response) {
                        $("#alertBox").removeClass("d-none alert-danger").addClass("alert-success")
                                      .text("Soru başarıyla eklendi! Sayfa temizleniyor...");

                        // Formu sıfırla ki admin peş peşe soru ekleyebilsin
                        $("#addQuestionForm")[0].reset();
                        // Şıkları tekrar 2 taneye düşür
                        $("#choicesContainer .choice-row:gt(1)").remove();

                        setTimeout(() => { $("#alertBox").addClass("d-none"); }, 3000);
                    },
                    error: function (err) {
                        $("#alertBox").removeClass("d-none alert-success").addClass("alert-danger")
                                      .text("Hata: Soru eklenemedi.");
                    }
                });
            });
        });
    </script>
}