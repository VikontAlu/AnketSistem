@{
    ViewData["Title"] = "Anket Coz";
    var apiBaseUrl = ViewBag.ApiBaseUrl as string ?? "http://localhost:5229";
}

<div class="container mt-4" style="max-width: 800px;">

    <div id="loadingPoll" class="text-center my-5">
        <div class="spinner-border text-primary" role="status"></div>
        <p class="mt-3 text-muted">Anket sorulari hazirlaniyor...</p>
    </div>

    <div id="pollContainer" class="d-none">
        <div class="card shadow-sm border-0 mb-4">
            <div class="card-body text-center bg-primary text-white rounded">
                <h2 id="pollTitle" class="fw-bold"></h2>
                <p id="pollDetail" class="mb-0"></p>
            </div>
        </div>

        <div id="alertBox" class="alert d-none"></div>

        <form id="pollForm">
            <div id="questionsList"></div>

            <div class="text-end mt-4 mb-5">
                <button type="submit" class="btn btn-success btn-lg fw-bold px-5 shadow">
                    <i class="bi bi-send-check"></i> Cevaplari Gonder
                </button>
            </div>
        </form>

        <div id="feedbackContainer" class="card shadow-lg border-0 d-none text-center p-5 mt-4">
            <h3 class="text-success fw-bold">&#10003; Tebrikler!</h3>
            <p class="text-muted">Cevaplar basariyla kaydedildi. Bu anketi nasil degerlendirirsiniz?</p>

            <select id="pollScore" class="form-select form-select-lg w-50 mx-auto mb-3 text-center text-warning fw-bold">
                <option value="5">&#11088;&#11088;&#11088;&#11088;&#11088; Harika</option>
                <option value="4">&#11088;&#11088;&#11088;&#11088; Iyi</option>
                <option value="3">&#11088;&#11088;&#11088; Orta</option>
                <option value="2">&#11088;&#11088; Kotu</option>
                <option value="1">&#11088; Cok Kotu</option>
            </select>

            <textarea id="pollComment" class="form-control mb-4" rows="2" placeholder="Gorusleriniz bizim icin degerli..."></textarea>

            <div>
                <button id="sendFeedbackBtn" class="btn btn-warning fw-bold px-4">Puani Gonder</button>
                <a href="/Home/Index" class="btn btn-outline-secondary px-4 ms-2">Degerlendirmeden Cik</a>
            </div>
        </div>

    </div>
</div>

@section Scripts {
    <script>
        const currentPollId = @ViewBag.PollId;
        // BUG FIX #7: API URL Razor'dan geliyor
        const apiBaseUrl = "@apiBaseUrl";

        $(document).ready(function () {

            // 1. Sorulari Getir
            $.ajax({
                url: `${apiBaseUrl}/api/Poll/${currentPollId}`,
                type: "GET",
                success: function (poll) {
                    $("#loadingPoll").addClass("d-none");
                    $("#pollContainer").removeClass("d-none");

                    $("#pollTitle").text(poll.title);
                    $("#pollDetail").text(poll.detail ? poll.detail : "Bu anket icin aciklama bulunmamaktadir.");

                    let questionsHtml = "";
                    if (poll.questions && poll.questions.length > 0) {
                        poll.questions.forEach((q, index) => {
                            questionsHtml += `
                                <div class="card shadow-sm border-0 mb-4">
                                    <div class="card-header bg-light border-0 pt-3">
                                        <!-- BUG FIX #5: q.text yerine q.questionText kullaniliyor -->
                                        <h5 class="fw-bold text-dark"><span class="text-primary">${index + 1}.</span> ${q.questionText}</h5>
                                    </div>
                                    <div class="card-body">
                            `;

                            if (q.choices && q.choices.length > 0) {
                                q.choices.forEach(choice => {
                                    questionsHtml += `
                                        <div class="form-check mb-2">
                                            <input class="form-check-input" type="radio" name="question_${q.id}" id="choice_${choice.id}" value="${choice.id}" required>
                                            <!-- BUG FIX #5: choice.text yerine choice.choiceText kullaniliyor -->
                                            <label class="form-check-label ms-2" for="choice_${choice.id}">
                                                ${choice.choiceText}
                                            </label>
                                        </div>
                                    `;
                                });
                            }
                            questionsHtml += `</div></div>`;
                        });
                        $("#questionsList").html(questionsHtml);
                    } else {
                        $("#questionsList").html("<div class='alert alert-warning'>Bu ankete henuz soru eklenmemis.</div>");
                        $("button[type='submit']").hide();
                    }
                },
                error: function () {
                    $("#loadingPoll").html("<div class='alert alert-danger'>Anket bulunamadi.</div>");
                }
            });

            // 2. Anket Cevaplarini Gonder
            $("#pollForm").submit(function (e) {
                e.preventDefault();

                const token = localStorage.getItem("token");
                if (!token) {
                    alert("Anketi cozmek icin lutfen giris yapin!");
                    window.location.href = "/Auth/Login";
                    return;
                }

                let answers = [];
                $("input[type='radio']:checked").each(function () {
                    let qId = $(this).attr("name").split("_")[1];
                    let cId = $(this).val();

                    answers.push({
                        // BUG FIX #4: Alan adlari API DTO'suyla eslesiyor (questionId, selectedOptionId)
                        questionId: parseInt(qId),
                        selectedOptionId: parseInt(cId)
                    });
                });

                $.ajax({
                    // BUG FIX #4: Dogru endpoint URL'si (/Submit + pollId query param)
                    url: `${apiBaseUrl}/api/Response/Submit?pollId=${currentPollId}`,
                    type: "POST",
                    contentType: "application/json",
                    headers: { "Authorization": "Bearer " + token },
                    data: JSON.stringify(answers),
                    success: function (res) {
                        $("#pollForm").slideUp("fast", function() {
                            $("#feedbackContainer").removeClass("d-none").hide().fadeIn("slow");
                        });
                    },
                    error: function (err) {
                        let msg = "Hata olustu!";
                        if (err.responseJSON && err.responseJSON.message) {
                            msg = err.responseJSON.message;
                        }
                        alert(msg);
                    }
                });
            });

            // 3. Yildizli Geri Bildirimi Gonder
            $("#sendFeedbackBtn").click(function() {
                const token = localStorage.getItem("token");
                const feedbackData = {
                    pollId: currentPollId,
                    score: parseInt($("#pollScore").val()),
                    userComment: $("#pollComment").val()
                };

                $.ajax({
                    url: `${apiBaseUrl}/api/PollFeedback`,
                    type: "POST",
                    contentType: "application/json",
                    headers: { "Authorization": "Bearer " + token },
                    data: JSON.stringify(feedbackData),
                    success: function (res) {
                        $("#feedbackContainer").html(`<h4 class='text-success fw-bold'>Degerlendirmeniz icin tesekkurler!</h4><p>Ana sayfaya yonlendiriliyorsunuz...</p>`);
                        setTimeout(() => { window.location.href = "/Home/Index"; }, 2500);
                    },
                    error: function(err) {
                        alert("Degerlendirme gonderilirken bir hata olustu.");
                    }
                });
            });
        });
    </script>
}
