@{
    Layout = null;
    var apiBaseUrl = ViewBag.ApiBaseUrl as string ?? "http://localhost:5229";
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <title>Giris Yap | Anket Sistemi</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body {
            background: #f4f7f6;
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .login-card {
            width: 400px;
            border: none;
            border-radius: 15px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
        }

        .btn-primary {
            background: #2575fc;
            border: none;
            border-radius: 8px;
            padding: 12px;
        }
    </style>
</head>
<body>

    <div class="card login-card p-4">
        <div class="text-center mb-4">
            <h3 class="fw-bold text-primary">Hos Geldiniz</h3>
            <p class="text-muted">Anket Sistemine Giris Yapin</p>
        </div>
        <div id="alertBox" class="alert d-none"></div>
        <form id="loginForm">
            <div class="mb-3">
                <label class="form-label fw-bold">E-Posta</label>
                <input type="email" id="email" class="form-control form-control-lg" placeholder="ornek@mail.com" required>
            </div>
            <div class="mb-4">
                <label class="form-label fw-bold">Sifre</label>
                <input type="password" id="password" class="form-control form-control-lg" placeholder="******" required>
            </div>
            <button type="submit" class="btn btn-primary w-100 fw-bold">Giris Yap</button>
            <div class="text-center mt-3">
                <a href="/Auth/Register" class="text-decoration-none text-secondary">Hesabin yok mu? Kayit Ol</a>
            </div>
        </form>
        <div class="text-center mt-3">
            <a href="/Auth/ForgotPassword" class="text-decoration-none text-danger small">Şifremi Unuttum</a>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        const apiBaseUrl = "@apiBaseUrl";

        $(document).ready(function () {
            $("#loginForm").submit(function (e) {
                e.preventDefault();

                const loginData = {
                    email: $("#email").val(),
                    password: $("#password").val()
                };

                $.ajax({
                    url: apiBaseUrl + "/api/Auth/login",
                    type: "POST",
                    contentType: "application/json",
                    data: JSON.stringify(loginData),
                    success: function (response) {
                        localStorage.setItem("token", response.token);
                        localStorage.setItem("isAdmin", response.isAdmin ? "true" : "false");

                        $("#alertBox").removeClass("d-none alert-danger").addClass("alert-success")
                                      .text("Giris Basarili! Yonlendiriliyorsunuz...");

                        setTimeout(() => {
                            if (response.isAdmin) {
                                window.location.href = "/Admin/Index";
                            } else {
                                window.location.href = "/Home/Index";
                            }
                        }, 1500);
                    },
                    error: function (err) {
                        $("#alertBox").removeClass("d-none alert-success").addClass("alert-danger")
                                      .text("Hata: E-posta veya sifre yanlis!");
                    }
                });
            });
        });
    </script>
</body>
</html>
