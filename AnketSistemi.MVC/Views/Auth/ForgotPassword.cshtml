@{
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <title>Şifremi Unuttum</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
    <div class="container mt-5" style="max-width:500px;">
        <div class="card shadow">
            <div class="card-body">
                <h3 class="mb-4 text-center">Şifre Sıfırlama</h3>
                <div id="alertBox" class="alert d-none"></div>
                <form id="forgotForm">
                    <div class="mb-3">
                        <label>E-posta adresiniz</label>
                        <input type="email" id="email" class="form-control" required>
                    </div>
                    <button type="submit" class="btn btn-primary w-100">Token Al</button>
                </form>
                <div id="tokenArea" class="d-none mt-4">
                    <hr>
                    <p><strong>Token (geliştirme modunda):</strong></p>
                    <code id="tokenText" class="user-select-all"></code>
                    <a id="resetLink" href="#" class="btn btn-success w-100 mt-2">Şifre Sıfırlama Sayfasına Git</a>
                </div>
                <div class="text-center mt-3">
                    <a href="/Auth/Login">Giriş sayfasına dön</a>
                </div>
            </div>
        </div>
    </div>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        const apiBaseUrl = "http://localhost:5229"; 
        $("#forgotForm").submit(function(e){
            e.preventDefault();
            $.ajax({
                url: `${apiBaseUrl}/api/Auth/forgot-password`,
                type: "POST",
                contentType: "application/json",
                data: JSON.stringify({ email: $("#email").val() }),
                success: function(res){
                    if (res.token) {
                        $("#tokenText").text(res.token);
                        $("#resetLink").attr("href", `/Auth/ResetPassword?email=${encodeURIComponent(res.email)}&token=${encodeURIComponent(res.token)}`);
                        $("#tokenArea").removeClass("d-none");
                        $("#alertBox").addClass("d-none");
                    } else {
                        $("#alertBox").removeClass("d-none alert-success").addClass("alert-info").text(res.message);
                    }
                }
            });
        });
    </script>
</body>
</html>