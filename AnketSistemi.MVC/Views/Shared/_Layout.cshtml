<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Anket Sistemi</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="bg-light">
    <header>
        <nav class="navbar navbar-expand-sm navbar-light bg-white border-bottom box-shadow mb-4">
            <div class="container">
                <a class="navbar-brand fw-bold text-primary" asp-controller="Home" asp-action="Index">&#128640; Anket Sistemi</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav me-auto">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-controller="Home" asp-action="Index">Ana Sayfa</a>
                        </li>
                    </ul>
                    <ul class="navbar-nav" id="authMenu"></ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        $(document).ready(function () {
            const token = localStorage.getItem("token");
            const isAdmin = localStorage.getItem("isAdmin") === "true";
            let menuHtml = "";

            if (token) {
                menuHtml = `
                    <li class="nav-item">${isAdmin ? '<a class="nav-link text-warning fw-bold" href="/Admin/Index">Admin Panel</a>' : ''}</li>
                    <li class="nav-item"><button class="btn btn-outline-danger btn-sm mt-1 ms-2" onclick="logout()">Cikis Yap</button></li>
                `;
            } else {
                menuHtml = `
                    <li class="nav-item"><a class="nav-link text-dark" href="/Auth/Login">Giris Yap</a></li>
                    <li class="nav-item"><a class="btn btn-primary btn-sm mt-1 ms-2" href="/Auth/Register">Kayit Ol</a></li>
                `;
            }
            $("#authMenu").html(menuHtml);
        });

        function logout() {
            localStorage.removeItem("token");
            localStorage.removeItem("isAdmin");
            window.location.href = "/Auth/Login";
        }
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
